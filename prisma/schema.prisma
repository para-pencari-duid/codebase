generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// TENANT FOUNDATION
// ============================================================

model Tenant {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  logo          String?
  address       String?
  phone         String?
  email         String?
  // Modules: "POS" | "BOM" | "JOB_TICKET" | "B2B" | "MULTI_STORE" | "LOYALTY" | "PRODUCTION"
  activeModules String[]
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users            User[]
  settings         Settings?
  items            Item[]
  itemCategories   ItemCategory[]
  customers        Customer[]
  suppliers        Supplier[]
  transactions     Transaction[]
  shifts           Shift[]
  expenses         Expense[]
  discounts        Discount[]
  stores           Store[]
  stockOpnames     StockOpname[]
  jobTickets       JobTicket[]
  purchases        Purchase[]
  returns          Return[]
  productionOrders ProductionOrder[]
  modifierGroups   ItemModifierGroup[]
  // Tier 2
  tables           Table[]
  tableOrders      TableOrder[]
  kitchenTickets   KitchenTicket[]
  bookings         Booking[]
  // Tier 3 — Retail & Wholesale (implicit tenantId-scoped, no direct relation needed)
  // Tier 4 — Accounting (via tenantId)
  // Tier 5 — Marketing (via tenantId)
  // Tier 6 — Platform (via tenantId)
  subscription  TenantSubscription?

  @@index([slug])
  @@index([isActive])
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  name          String?
  password      String?
  role          Role      @default(KASIR)
  phone         String?
  image         String?
  isActive      Boolean   @default(true)
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  stockMovements    StockMovement[]
  jobTickets        JobTicket[]
  staffBookings     Booking[]       @relation("BookingStaff")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

enum Role {
  OWNER
  MANAGER
  KASIR
}

// ============================================================
// UNIVERSAL ITEM CATALOG
// ============================================================

model ItemCategory {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  icon        String?
  color       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  Item[]

  @@index([tenantId])
  @@index([name])
}

// Item menggantikan Product + RawMaterial
model Item {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String   // unique per tenant
  name        String
  description String?
  type        ItemType @default(GOODS)
  categoryId  String?
  images      String[]
  isActive    Boolean  @default(true)
  // Harga/biaya default; variant bisa override
  basePrice   Decimal  @db.Decimal(10, 2)
  baseCost    Decimal? @db.Decimal(10, 2)
  unit        String   @default("pcs")
  taxable      Boolean  @default(true)
  serialTrack  Boolean  @default(false)
  taxRateId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category      ItemCategory? @relation(fields: [categoryId], references: [id])
  variants      ItemVariant[]
  bom           BillOfMaterial?
  // Digunakan sebagai komponen dalam BOM milik item lain
  bomComponents BomItem[]     @relation("BomComponentItem")
  modifierGroups ItemModifierGroup[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([categoryId])
  @@index([name])
}

enum ItemType {
  GOODS        // Produk jual
  SERVICE      // Jasa (tidak memotong stok)
  RAW_MATERIAL // Bahan baku produksi
  BUNDLE       // Bundel / paket
}

// Stok fisik dihitung di level variant
// Item sederhana (tanpa variant) tetap punya 1 default variant
model ItemVariant {
  id         String   @id @default(cuid())
  itemId     String
  tenantId   String
  sku        String   // unique per tenant
  name       String   // "Default" | "Ukuran L - Merah"
  price      Decimal  @db.Decimal(10, 2)
  cost       Decimal? @db.Decimal(10, 2)
  stock      Int      @default(0)
  minStock   Int      @default(10)
  barcode    String?
  isActive   Boolean  @default(true)
  // JSON attributes: {"size": "L", "color": "Red"}
  attributes String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  item             Item                @relation(fields: [itemId], references: [id], onDelete: Cascade)
  transactionItems TransactionItem[]
  stockMovements   StockMovement[]
  storeInventory   StoreInventory[]
  batches          ItemBatch[]
  returnItems      ReturnItem[]
  transferItems    StoreTransferItem[]
  purchaseItems    PurchaseItem[]
  opnameItems      StockOpnameItem[]
  bomItems         BomItem[]
  tableOrderItems  TableOrderItem[]
  priceListItems   PriceListItem[]
  consignmentItems ConsignmentItem[]
  serialNumbers    SerialNumber[]

  @@unique([tenantId, sku])
  @@index([tenantId, isActive])     // POS hanya load barang aktif
  @@index([tenantId, barcode])     // scan barcode ultra-cepat
  @@index([itemId])
}

// ============================================================
// BILL OF MATERIALS — menggantikan Recipe
// ============================================================

model BillOfMaterial {
  id        String   @id @default(cuid())
  tenantId  String
  itemId    String   @unique // Item yang DIHASILKAN
  notes     String?
  yield     Decimal  @db.Decimal(10, 3) @default(1)
  yieldUnit String   @default("pcs")
  prepTime  Int?     // menit
  cookTime  Int?     // menit
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item       Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  components BomItem[]

  @@index([tenantId])
  @@index([itemId])
}

model BomItem {
  id              String          @id @default(cuid())
  bomId           String
  componentItemId String          // Item bahan baku / komponen
  variantId       String?         // Opsional: variant spesifik
  quantity        Decimal         @db.Decimal(10, 3)
  unit            String
  notes           String?
  createdAt       DateTime        @default(now())

  bom           BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentItem Item           @relation("BomComponentItem", fields: [componentItemId], references: [id])
  variant       ItemVariant?   @relation(fields: [variantId], references: [id])

  @@index([bomId])
  @@index([componentItemId])
  @@index([variantId])
}

// ============================================================
// PRODUCTION ORDERS
// ============================================================

model ProductionOrder {
  id            String           @id @default(cuid())
  tenantId      String
  orderNo       String
  status        ProductionStatus @default(PLANNED)
  scheduledDate DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  totalCost     Decimal          @db.Decimal(10, 2) @default(0)
  notes         String?
  userId        String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     ProductionOrderItem[]
  materials ProductionMaterial[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([status])
  @@index([scheduledDate])
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionOrderItem {
  id               String @id @default(cuid())
  productionId     String
  variantId        String
  itemName         String
  variantName      String
  targetQuantity   Int
  producedQuantity Int    @default(0)
  wasteQuantity    Int    @default(0)
  notes            String?

  production ProductionOrder @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId])
  @@index([variantId])
}

model ProductionMaterial {
  id           String  @id @default(cuid())
  productionId String
  variantId    String
  materialName String
  quantity     Decimal @db.Decimal(10, 3)
  unit         String
  cost         Decimal @db.Decimal(10, 2)

  production ProductionOrder @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId])
  @@index([variantId])
}

// ============================================================
// JOB TICKET — menggantikan PreOrder
// Mendukung: Cuci Sepatu, Custom Cake, Servis, dll.
// ============================================================

model JobTicket {
  id              String        @id @default(cuid())
  tenantId        String
  ticketNo        String
  customerName    String
  customerPhone   String
  customerAddress String?
  // Judul & deskripsi pekerjaan
  title           String        // "Cuci Sepatu Nike", "Black Forest 22cm"
  description     String?
  notes           String?
  referenceImages String[]
  // Pricing
  quantity        Int           @default(1)
  unitPrice       Decimal       @db.Decimal(10, 2)
  totalPrice      Decimal       @db.Decimal(10, 2)
  // DP
  dpAmount        Decimal       @db.Decimal(10, 2) @default(0)
  dpMethod        PaymentMethod?
  dpPaidAt        DateTime?
  // Pelunasan
  remainingAmount Decimal       @db.Decimal(10, 2) @default(0)
  finalPayMethod  PaymentMethod?
  finalPaidAt     DateTime?
  // Jadwal
  dueDate         DateTime
  deliveryType    DeliveryType  @default(PICKUP)
  // Status
  status          JobStatus     @default(PENDING)
  cancelReason    String?
  // Relasi
  createdBy       String
  customerId      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User            @relation(fields: [createdBy], references: [id])
  customer      Customer?       @relation(fields: [customerId], references: [id])
  items         JobTicketItem[]

  @@unique([tenantId, ticketNo])
  @@index([tenantId, status])                   // tab kanban per status
  @@index([tenantId, dueDate(sort: Asc)])       // deadline terdekat
  @@index([tenantId, customerPhone])            // cari tiket via WA
  @@index([createdAt])
}

model JobTicketItem {
  id        String      @id @default(cuid())
  ticketId  String
  variantId String?     // Opsional: link ke item dari katalog
  name      String
  quantity  Int         @default(1)
  unitPrice Decimal     @db.Decimal(10, 2)
  subtotal  Decimal     @db.Decimal(10, 2)
  notes     String?

  ticket JobTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([variantId])
}

enum JobStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

// ============================================================
// TRANSACTIONS — POS Receipt & B2B Invoice
// ============================================================

model Transaction {
  id            String               @id @default(cuid())
  tenantId      String
  transactionNo String
  type          TransactionType      @default(POS_RECEIPT)
  customerId    String?
  userId        String
  shiftId       String?
  subtotal      Decimal              @db.Decimal(10, 2)
  tax           Decimal              @db.Decimal(10, 2)
  discount      Decimal              @db.Decimal(10, 2) @default(0)
  total         Decimal              @db.Decimal(10, 2)
  paymentMethod PaymentMethod?
  paymentAmount Decimal              @db.Decimal(10, 2) @default(0)
  changeAmount  Decimal              @db.Decimal(10, 2) @default(0)
  // Untuk B2B invoice (tempo / piutang)
  paymentStatus InvoicePaymentStatus @default(PAID)
  dueDate       DateTime?
  notes         String?
  status        TransactionStatus    @default(COMPLETED)
  // Loyalty points
  pointsEarned  Int                  @default(0)
  pointsRedeemed Int                 @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer?        @relation(fields: [customerId], references: [id])
  user     User             @relation(fields: [userId], references: [id])
  shift    Shift?           @relation(fields: [shiftId], references: [id])
  items    TransactionItem[]
  payments TransactionPayment[]

  @@unique([tenantId, transactionNo])
  @@index([tenantId, createdAt(sort: Desc)])   // dashboard harian/bulanan
  @@index([tenantId, type, createdAt])          // B2B vs POS temporal
  @@index([tenantId, status])                   // filter COMPLETED/VOID
  @@index([tenantId, paymentStatus])            // piutang unpaid/partial
  @@index([customerId])
  @@index([userId])
  @@index([shiftId])
}

enum TransactionType {
  POS_RECEIPT  // Kasir / retail
  B2B_INVOICE  // Faktur wholesale / tempo
}

// Split payment per transaksi (multi-payment / split bill)
model TransactionPayment {
  id            String        @id @default(cuid())
  transactionId String
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  reference     String?       // nomor referensi manual (opsional)
  createdAt     DateTime      @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

enum InvoicePaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  DEBIT_CARD
  CREDIT_CARD
  EWALLET
  POINTS       // Loyalty point redemption
}

enum TransactionStatus {
  COMPLETED
  VOID
  REFUNDED
}

model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  variantId     String
  itemName      String
  variantName   String
  quantity      Int
  price         Decimal @db.Decimal(10, 2)
  discount      Decimal @db.Decimal(10, 2) @default(0)
  subtotal      Decimal @db.Decimal(10, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  variant     ItemVariant @relation(fields: [variantId], references: [id])
  modifiers   TransactionItemModifier[]

  @@index([transactionId])
  @@index([variantId])
}

// ============================================================
// ITEM MODIFIERS / ADD-ONS
// ============================================================

model ItemModifierGroup {
  id        String   @id @default(cuid())
  tenantId  String
  name      String   // "Level Gula", "Topping", "Ukuran"
  required  Boolean  @default(false)
  multiple  Boolean  @default(true)
  maxSelect Int?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  options ItemModifierOption[]
  items   Item[]              // implicit many-to-many

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model ItemModifierOption {
  id        String  @id @default(cuid())
  groupId   String
  name      String  // "Extra Shot", "Oat Milk", "Less Sugar"
  price     Decimal @db.Decimal(10, 2) @default(0)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  group ItemModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model TransactionItemModifier {
  id                 String  @id @default(cuid())
  transactionItemId  String
  modifierGroupName  String
  modifierOptionName String
  price              Decimal @db.Decimal(10, 2)

  transactionItem TransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: Cascade)

  @@index([transactionItemId])
}

// ============================================================
// STOCK MANAGEMENT
// ============================================================

model StockMovement {
  id        String            @id @default(cuid())
  tenantId  String
  variantId String
  type      StockMovementType
  quantity  Int
  reference String?
  reason    String?
  notes     String?
  userId    String
  createdAt DateTime          @default(now())

  variant ItemVariant @relation(fields: [variantId], references: [id])
  user    User        @relation(fields: [userId], references: [id])

  @@index([tenantId, variantId, createdAt(sort: Desc)])  // kartu stok per barang
  @@index([tenantId, type, createdAt(sort: Desc)])        // laporan IN/OUT harian
  @@index([variantId])
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

// Batch / lot tracking dengan expiry date
model ItemBatch {
  id              String      @id @default(cuid())
  tenantId        String
  variantId       String
  batchNo         String
  quantity        Int
  remainingQty    Int
  manufactureDate DateTime
  expiryDate      DateTime
  cost            Decimal     @db.Decimal(10, 2)
  supplier        String?
  notes           String?
  discountRate    Decimal     @db.Decimal(5, 2) @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  variant ItemVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, batchNo])
  @@index([tenantId])
  @@index([variantId])
  @@index([expiryDate])
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  phone        String?
  email        String?
  address      String?
  birthDate    DateTime?
  notes        String?
  customerType CustomerType @default(RETAIL)
  creditLimit  Decimal?     @db.Decimal(10, 2) // Untuk B2B
  priceListId  String?
  segment      String?      // "VIP" | "AT_RISK" | "NEW" | "REGULAR"
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  loyaltyPoints LoyaltyPoint?
  pointHistory  PointHistory[]
  jobTickets    JobTicket[]
  bookings      Booking[]
  priceList     PriceList?     @relation(fields: [priceListId], references: [id])

  @@index([tenantId])
  @@index([name])
  @@index([phone])
}

enum CustomerType {
  RETAIL
  WHOLESALE
}

model LoyaltyPoint {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String   @unique
  points      Int      @default(0)
  totalEarned Int      @default(0)
  totalSpent  Int      @default(0)
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
}

model PointHistory {
  id          String          @id @default(cuid())
  tenantId    String
  customerId  String
  points      Int
  type        PointActionType
  reference   String?
  description String?
  createdAt   DateTime        @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([createdAt])
}

enum PointActionType {
  EARN
  REDEEM
  EXPIRE
  ADJUSTMENT
}

// ============================================================
// SUPPLIERS & PURCHASES
// ============================================================

model Supplier {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  phone       String?
  email       String?
  address     String?
  contactName String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@index([tenantId])
  @@index([name])
}

model Purchase {
  id            String        @id @default(cuid())
  tenantId      String
  purchaseNo    String
  supplierId    String
  userId        String
  subtotal      Decimal       @db.Decimal(10, 2)
  tax           Decimal       @db.Decimal(10, 2) @default(0)
  discount      Decimal       @db.Decimal(10, 2) @default(0)
  total         Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@unique([tenantId, purchaseNo])
  @@index([tenantId])
  @@index([supplierId])
  @@index([createdAt])
}

model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String
  variantId   String
  itemName    String
  variantName String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  purchase Purchase    @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant  ItemVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([variantId])
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

// ============================================================
// DISCOUNTS
// ============================================================

model Discount {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)
  minPurchase Decimal?     @db.Decimal(10, 2)
  maxDiscount Decimal?     @db.Decimal(10, 2)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean      @default(true)
  usageLimit  Int?
  usageCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ============================================================
// EXPENSES
// ============================================================

model Expense {
  id            String          @id @default(cuid())
  tenantId      String
  category      ExpenseCategory
  amount        Decimal         @db.Decimal(10, 2)
  date          DateTime        @default(now())
  description   String
  paymentMethod PaymentMethod
  reference     String?
  notes         String?
  attachments   String[]
  userId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date(sort: Desc)])    // pengeluaran bulanan
  @@index([tenantId, category, date])      // breakdown per kategori
}

enum ExpenseCategory {
  SALARY
  UTILITIES
  RAW_MATERIALS
  SUPPLIES
  RENT
  MAINTENANCE
  MARKETING
  TRANSPORTATION
  TAX_FEE
  OTHER
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  type      NotificationType
  title     String
  message   String
  data      String?
  isRead    Boolean          @default(false)
  userId    String?
  createdAt DateTime         @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  NEW_ORDER
  SYSTEM
}

// ============================================================
// SETTINGS — Per Tenant
// ============================================================

model Settings {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  businessName          String
  businessAddress       String?
  businessPhone         String?
  businessEmail         String?
  logo                  String?
  taxRate               Decimal   @db.Decimal(5, 2) @default(11)
  taxIncluded           Boolean   @default(false)
  currency              String    @default("IDR")
  receiptHeader         String?
  receiptFooter         String?
  lowStockThreshold     Int       @default(10)
  whatsappEnabled       Boolean   @default(false)
  whatsappTenantId      String?
  whatsappConnected     Boolean   @default(false)
  whatsappLastConnected DateTime?
  notifyOnTransaction   Boolean   @default(false)
  notifyOnLowStock      Boolean   @default(true)
  notifyOnBackup        Boolean   @default(true)
  notifyDailyReport     Boolean   @default(false)
  ownerPhone            String?
  // QRIS Static String (konten text dari gambar QRIS statis)
  qrisString            String?   @db.Text
  // Loyalty Program Settings
  loyaltyEnabled        Boolean   @default(false)
  loyaltyPointsPerRupiah Int      @default(1000) // Rp per 1 poin
  loyaltyPointValue     Int       @default(1)    // 1 poin = Rp 1
  // Tier 2: Table & KDS
  tableEnabled          Boolean   @default(false)
  kdsEnabled            Boolean   @default(false)
  // Tier 3
  tierPricingEnabled    Boolean   @default(false)
  serialTrackEnabled    Boolean   @default(false)
  consignmentEnabled    Boolean   @default(false)
  // Tier 4
  accountingEnabled     Boolean   @default(false)
  bankReconEnabled      Boolean   @default(false)
  payrollEnabled        Boolean   @default(false)
  // Tier 5
  marketingEnabled      Boolean   @default(false)
  feedbackEnabled       Boolean   @default(false)
  // Tier 6
  onlineOrderEnabled    Boolean   @default(false)
  webhooksEnabled       Boolean   @default(false)
  updatedAt             DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ============================================================
// SHIFTS
// ============================================================

model Shift {
  id               String      @id @default(cuid())
  tenantId         String
  shiftNo          String
  userId           String
  storeId          String?
  openedAt         DateTime    @default(now())
  closedAt         DateTime?
  status           ShiftStatus @default(OPEN)
  openingBalance   Decimal     @db.Decimal(10, 2)
  closingBalance   Decimal?    @db.Decimal(10, 2)
  actualCash       Decimal?    @db.Decimal(10, 2)
  variance         Decimal?    @db.Decimal(10, 2)
  totalSales       Decimal     @db.Decimal(10, 2) @default(0)
  totalCash        Decimal     @db.Decimal(10, 2) @default(0)
  totalTransfer    Decimal     @db.Decimal(10, 2) @default(0)
  totalQris        Decimal     @db.Decimal(10, 2) @default(0)
  totalCard        Decimal     @db.Decimal(10, 2) @default(0)
  transactionCount Int         @default(0)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  store        Store?        @relation(fields: [storeId], references: [id])

  @@unique([tenantId, shiftNo])
  @@index([tenantId])
  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([openedAt])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// ============================================================
// RETURNS
// ============================================================

model Return {
  id            String       @id @default(cuid())
  tenantId      String
  returnNo      String
  transactionId String
  transactionNo String
  customerId    String?
  userId        String
  reason        String
  status        ReturnStatus @default(PENDING)
  subtotal      Decimal      @db.Decimal(10, 2)
  refundAmount  Decimal      @db.Decimal(10, 2)
  refundMethod  PaymentMethod
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  ReturnItem[]

  @@unique([tenantId, returnNo])
  @@index([tenantId])
  @@index([transactionId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model ReturnItem {
  id            String  @id @default(cuid())
  returnId      String
  variantId     String
  itemName      String
  variantName   String
  quantity      Int
  price         Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)
  returnToStock Boolean @default(true)
  condition     String? // GOOD, DAMAGED, EXPIRED

  return  Return      @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant ItemVariant @relation(fields: [variantId], references: [id])

  @@index([returnId])
  @@index([variantId])
}

// ============================================================
// STOCK OPNAME
// ============================================================

model StockOpname {
  id            String       @id @default(cuid())
  tenantId      String
  opnameNo      String
  scheduledDate DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  status        OpnameStatus @default(SCHEDULED)
  storeId       String?
  countedBy     String?
  verifiedBy    String?
  totalItems    Int          @default(0)
  totalVariance Int          @default(0)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  StockOpnameItem[]
  store  Store?            @relation(fields: [storeId], references: [id])

  @@unique([tenantId, opnameNo])
  @@index([tenantId])
  @@index([status])
  @@index([storeId])
  @@index([scheduledDate])
}

enum OpnameStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model StockOpnameItem {
  id           String  @id @default(cuid())
  opnameId     String
  variantId    String
  itemName     String
  variantName  String
  systemStock  Int
  countedStock Int     @default(0)
  variance     Int     @default(0)
  reason       String?
  condition    String? // GOOD, DAMAGED, EXPIRED
  adjusted     Boolean @default(false)
  notes        String?

  opname  StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  variant ItemVariant @relation(fields: [variantId], references: [id])

  @@index([opnameId])
  @@index([variantId])
}

// ============================================================
// MULTI-STORE
// ============================================================

model Store {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  address     String?
  phone       String?
  email       String?
  manager     String?
  isActive    Boolean  @default(true)
  isMainStore Boolean  @default(false)
  settings    String?  // JSON store-specific config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts         Shift[]
  stockOpnames   StockOpname[]
  storeInventory StoreInventory[]
  transfersFrom  StoreTransfer[]  @relation("TransferFrom")
  transfersTo    StoreTransfer[]  @relation("TransferTo")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

model StoreInventory {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  variantId String   // Stock dihitung per variant
  stock     Int      @default(0)
  minStock  Int      @default(10)
  maxStock  Int?
  updatedAt DateTime @updatedAt

  store   Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ItemVariant @relation(fields: [variantId], references: [id])

  @@unique([storeId, variantId])
  @@index([tenantId])
  @@index([storeId])
  @@index([variantId])
}

model StoreTransfer {
  id          String         @id @default(cuid())
  tenantId    String
  transferNo  String
  fromStoreId String
  toStoreId   String
  status      TransferStatus @default(PENDING)
  requestedBy String
  approvedBy  String?
  receivedBy  String?
  requestedAt DateTime       @default(now())
  approvedAt  DateTime?
  receivedAt  DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  fromStore Store               @relation("TransferFrom", fields: [fromStoreId], references: [id])
  toStore   Store               @relation("TransferTo", fields: [toStoreId], references: [id])
  items     StoreTransferItem[]

  @@unique([tenantId, transferNo])
  @@index([tenantId])
  @@index([fromStoreId])
  @@index([toStoreId])
  @@index([status])
}

enum TransferStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  RECEIVED
  REJECTED
}

model StoreTransferItem {
  id          String  @id @default(cuid())
  transferId  String
  variantId   String
  itemName    String
  variantName String
  quantity    Int
  receivedQty Int     @default(0)
  notes       String?

  transfer StoreTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ItemVariant   @relation(fields: [variantId], references: [id])

  @@index([transferId])
  @@index([variantId])
}

// ============================================================
// TIER 2: TABLE MANAGEMENT
// ============================================================

model Table {
  id          String      @id @default(cuid())
  tenantId    String
  storeId     String?
  number      String      // "1", "A1", "VIP-1"
  name        String?     // "Meja Pojok", "Outdoor 3"
  capacity    Int         @default(4)
  floor       String?     // "Lantai 1", "Outdoor", "VIP"
  status      TableStatus @default(AVAILABLE)
  qrToken     String      @unique @default(cuid())
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activeOrder TableOrder?

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, isActive])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

model TableOrder {
  id            String           @id @default(cuid())
  tenantId      String
  tableId       String           @unique
  orderNo       String
  customerId    String?
  guestName     String?
  guestCount    Int              @default(1)
  status        TableOrderStatus @default(OPEN)
  notes         String?
  openedBy      String
  openedAt      DateTime         @default(now())
  closedAt      DateTime?
  transactionId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table          Table            @relation(fields: [tableId], references: [id])
  items          TableOrderItem[]
  kitchenTickets KitchenTicket[]

  @@unique([tenantId, orderNo])
  @@index([tenantId, status])
  @@index([tableId])
}

enum TableOrderStatus {
  OPEN
  BILL_REQUESTED
  PAID
  CANCELLED
}

model TableOrderItem {
  id           String            @id @default(cuid())
  tableOrderId String
  variantId    String
  itemName     String
  variantName  String
  quantity     Int
  price        Decimal           @db.Decimal(10, 2)
  notes        String?
  status       KitchenItemStatus @default(PENDING)
  sentAt       DateTime?
  createdAt    DateTime          @default(now())

  tableOrder TableOrder  @relation(fields: [tableOrderId], references: [id], onDelete: Cascade)
  variant    ItemVariant @relation(fields: [variantId], references: [id])

  @@index([tableOrderId])
  @@index([variantId])
}

// ============================================================
// TIER 2: KITCHEN DISPLAY SYSTEM (KDS)
// ============================================================

model KitchenTicket {
  id           String        @id @default(cuid())
  tenantId     String
  ticketNo     String
  tableOrderId String?
  tableNumber  String?
  source       KitchenSource @default(POS)
  status       KitchenStatus @default(PENDING)
  priority     Int           @default(0)
  notes        String?
  startedAt    DateTime?
  readyAt      DateTime?
  servedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tableOrder TableOrder?        @relation(fields: [tableOrderId], references: [id])
  items      KitchenTicketItem[]

  @@unique([tenantId, ticketNo])
  @@index([tenantId, status])
  @@index([tableOrderId])
  @@index([createdAt])
}

model KitchenTicketItem {
  id          String            @id @default(cuid())
  ticketId    String
  variantId   String?
  itemName    String
  quantity    Int
  notes       String?
  status      KitchenItemStatus @default(PENDING)
  completedAt DateTime?

  ticket KitchenTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

enum KitchenStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum KitchenSource {
  TABLE
  POS
  SELF_ORDER
}

enum KitchenItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

// ============================================================
// TIER 2: BOOKINGS / APPOINTMENTS
// ============================================================

model Booking {
  id            String        @id @default(cuid())
  tenantId      String
  bookingNo     String
  customerId    String?
  customerName  String
  customerPhone String?
  serviceId     String?
  serviceName   String
  staffId       String?
  storeId       String?
  date          DateTime
  startTime     DateTime
  endTime       DateTime?
  duration      Int?          // minutes
  status        BookingStatus @default(PENDING)
  notes         String?
  reminderSent  Boolean       @default(false)
  depositPaid   Decimal?      @db.Decimal(10, 2)
  totalAmount   Decimal?      @db.Decimal(10, 2)
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  staff    User?     @relation("BookingStaff", fields: [staffId], references: [id])

  @@unique([tenantId, bookingNo])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([staffId])
  @@index([customerId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================================
// TIER 3: TIER PRICING / PRICE LIST
// ============================================================

model PriceList {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  minOrderQty Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items     PriceListItem[]
  customers Customer[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model PriceListItem {
  id          String  @id @default(cuid())
  priceListId String
  variantId   String
  price       Decimal @db.Decimal(10, 2)
  minQty      Int     @default(1)

  priceList PriceList   @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  variant   ItemVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([priceListId, variantId])
  @@index([priceListId])
  @@index([variantId])
}

// ============================================================
// TIER 3: CONSIGNMENT / TITIP JUAL
// ============================================================

model Consignment {
  id            String             @id @default(cuid())
  tenantId      String
  consignNo     String
  consignerName String
  consignerPhone String?
  supplierId    String?
  startDate     DateTime
  endDate       DateTime?
  status        ConsignmentStatus  @default(ACTIVE)
  notes         String?
  commission    Decimal            @db.Decimal(5, 2) @default(0) // % komisi
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  items ConsignmentItem[]

  @@unique([tenantId, consignNo])
  @@index([tenantId, status])
}

model ConsignmentItem {
  id             String      @id @default(cuid())
  consignmentId  String
  variantId      String
  itemName       String
  variantName    String
  consignedQty   Int
  soldQty        Int         @default(0)
  returnedQty    Int         @default(0)
  consignPrice   Decimal     @db.Decimal(10, 2)
  salePrice      Decimal     @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())

  consignment Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  variant     ItemVariant @relation(fields: [variantId], references: [id])

  @@index([consignmentId])
  @@index([variantId])
}

enum ConsignmentStatus {
  ACTIVE
  SETTLED
  RETURNED
  CANCELLED
}

// ============================================================
// TIER 3: SERIAL NUMBER TRACKING
// ============================================================

model SerialNumber {
  id            String             @id @default(cuid())
  tenantId      String
  variantId     String
  serialNo      String
  status        SerialNumberStatus @default(IN_STOCK)
  purchaseRef   String?
  transactionId String?
  customerId    String?
  soldAt        DateTime?
  returnedAt    DateTime?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  variant ItemVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, serialNo])
  @@index([tenantId, status])
  @@index([variantId])
  @@index([transactionId])
}

enum SerialNumberStatus {
  IN_STOCK
  SOLD
  RETURNED
  DEFECTIVE
  RESERVED
}

// ============================================================
// TIER 4: CHART OF ACCOUNTS
// ============================================================

model Account {
  id             String      @id @default(cuid())
  tenantId       String
  code           String
  name           String
  type           AccountType
  normalBalance  BalanceSide @default(DEBIT)
  parentId       String?
  description    String?
  isActive       Boolean     @default(true)
  isSystem       Boolean     @default(false) // akun sistem otomatis
  currentBalance Decimal     @db.Decimal(15, 2) @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  parent   Account?        @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[]       @relation("AccountHierarchy")
  lines    JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([tenantId, isActive])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum BalanceSide {
  DEBIT
  CREDIT
}

model JournalEntry {
  id          String         @id @default(cuid())
  tenantId    String
  entryNo     String
  date        DateTime
  description String
  reference   String?
  sourceType  String?        // "TRANSACTION" | "EXPENSE" | "PAYROLL" | "MANUAL"
  sourceId    String?
  isPosted    Boolean        @default(false)
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  lines JournalLine[]

  @@unique([tenantId, entryNo])
  @@index([tenantId, date])
  @@index([tenantId, isPosted])
  @@index([sourceId])
}

model JournalLine {
  id          String  @id @default(cuid())
  entryId     String
  accountId   String
  description String?
  debit       Decimal @db.Decimal(15, 2) @default(0)
  credit      Decimal @db.Decimal(15, 2) @default(0)
  sortOrder   Int     @default(0)

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
}

// ============================================================
// TIER 4: BANK RECONCILIATION
// ============================================================

model BankAccount {
  id             String   @id @default(cuid())
  tenantId       String
  bankName       String
  accountNumber  String
  accountName    String
  currentBalance Decimal  @db.Decimal(15, 2) @default(0)
  currency       String   @default("IDR")
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  statements BankStatement[]

  @@unique([tenantId, accountNumber])
  @@index([tenantId, isActive])
}

model BankStatement {
  id            String            @id @default(cuid())
  tenantId      String
  bankAccountId String
  date          DateTime
  description   String
  amount        Decimal           @db.Decimal(15, 2)
  type          BankTxType
  reference     String?
  balance       Decimal?          @db.Decimal(15, 2)
  isReconciled  Boolean           @default(false)
  transactionId String?
  notes         String?
  createdAt     DateTime          @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId, bankAccountId])
  @@index([tenantId, date])
  @@index([isReconciled])
}

enum BankTxType {
  CREDIT
  DEBIT
}

// ============================================================
// TIER 4: TAX RATES
// ============================================================

model TaxRate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String   // "PPN 12%", "PPh 23"
  code        String
  rate        Decimal  @db.Decimal(5, 2)
  isDefault   Boolean  @default(false)
  isInclusive Boolean  @default(false) // harga sudah termasuk pajak
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

// ============================================================
// TIER 4: PAYROLL
// ============================================================

model Employee {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String?
  employeeNo  String
  name        String
  position    String?
  department  String?
  joinDate    DateTime
  baseSalary  Decimal   @db.Decimal(15, 2)
  bankName    String?
  bankAccount String?
  bankHolder  String?
  phone       String?
  address     String?
  isActive    Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  attendances    Attendance[]
  payrollEntries PayrollEntry[]

  @@unique([tenantId, employeeNo])
  @@index([tenantId, isActive])
}

model Attendance {
  id         String           @id @default(cuid())
  tenantId   String
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  notes      String?
  createdAt  DateTime         @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId, date])
  @@index([employeeId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  HOLIDAY
  LEAVE
}

model PayrollPeriod {
  id         String        @id @default(cuid())
  tenantId   String
  name       String
  startDate  DateTime
  endDate    DateTime
  status     PayrollStatus @default(DRAFT)
  notes      String?
  processedBy String?
  processedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  entries PayrollEntry[]

  @@index([tenantId, status])
  @@index([tenantId, startDate])
}

model PayrollEntry {
  id           String        @id @default(cuid())
  periodId     String
  tenantId     String
  employeeId   String
  workingDays  Int           @default(0)
  presentDays  Int           @default(0)
  baseSalary   Decimal       @db.Decimal(15, 2)
  allowances   Decimal       @db.Decimal(15, 2) @default(0)
  deductions   Decimal       @db.Decimal(15, 2) @default(0)
  netSalary    Decimal       @db.Decimal(15, 2)
  bankName     String?
  bankAccount  String?
  status       PayrollStatus @default(DRAFT)
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  period   PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id])

  @@unique([periodId, employeeId])
  @@index([tenantId, periodId])
  @@index([employeeId])
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
  CANCELLED
}

// ============================================================
// TIER 5: MARKETING CAMPAIGNS
// ============================================================

model MarketingCampaign {
  id             String         @id @default(cuid())
  tenantId       String
  name           String
  type           CampaignType
  targetSegment  String?        // "ALL" | "VIP" | "AT_RISK" | custom
  message        String         @db.Text
  imageUrl       String?
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  totalRecipients Int           @default(0)
  sentCount      Int            @default(0)
  failedCount    Int            @default(0)
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  recipients CampaignRecipient[]

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  customerId String?
  name       String?
  contact    String          // phone or email
  status     RecipientStatus @default(PENDING)
  sentAt     DateTime?
  errorMsg   String?

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([customerId])
}

enum CampaignType {
  WHATSAPP
  EMAIL
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// ============================================================
// TIER 5: CUSTOMER FEEDBACK / NPS
// ============================================================

model CustomerFeedback {
  id            String   @id @default(cuid())
  tenantId      String
  customerId    String?
  transactionId String?
  rating        Int      // 1-5
  comment       String?  @db.Text
  channel       String   @default("LINK") // "WHATSAPP" | "QR" | "LINK"
  staffName     String?
  storeId       String?
  isPublic      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, rating])
  @@index([customerId])
  @@index([transactionId])
}

// ============================================================
// TIER 6: WEBHOOKS
// ============================================================

model WebhookEndpoint {
  id          String   @id @default(cuid())
  tenantId    String
  url         String
  description String?
  events      String[] // ["transaction.created", "order.paid", ...]
  secret      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs WebhookLog[]

  @@index([tenantId, isActive])
}

model WebhookLog {
  id           String   @id @default(cuid())
  endpointId   String
  tenantId     String
  event        String
  payload      String   @db.Text
  status       String   @default("PENDING") // PENDING | SUCCESS | FAILED
  responseCode Int?
  responseBody String?  @db.Text
  attemptCount Int      @default(0)
  nextRetryAt  DateTime?
  createdAt    DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([endpointId])
  @@index([status])
}

// ============================================================
// TIER 6: MARKETPLACE INTEGRATION
// ============================================================

model MarketplaceIntegration {
  id          String    @id @default(cuid())
  tenantId    String
  platform    String    // "TOKOPEDIA" | "SHOPEE" | "GOFOOD" | "GRABFOOD" | "TRAVELOKA"
  shopId      String?
  shopName    String?
  apiKey      String?   @db.Text
  apiSecret   String?   @db.Text
  accessToken String?   @db.Text
  isActive    Boolean   @default(false)
  lastSyncAt  DateTime?
  syncStatus  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders MarketplaceOrder[]

  @@unique([tenantId, platform])
  @@index([tenantId, isActive])
}

model MarketplaceOrder {
  id              String    @id @default(cuid())
  integrationId   String
  tenantId        String
  externalOrderId String
  platform        String
  status          String    // platform-specific status
  customerName    String?
  customerPhone   String?
  items           String    @db.Text  // JSON
  subtotal        Decimal   @db.Decimal(10, 2) @default(0)
  shippingFee     Decimal   @db.Decimal(10, 2) @default(0)
  total           Decimal   @db.Decimal(10, 2) @default(0)
  transactionId   String?
  syncedAt        DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalOrderId])
  @@index([tenantId, platform])
  @@index([tenantId, status])
}

// ============================================================
// TIER 6: SUBSCRIPTION / TENANT BILLING
// ============================================================

model SubscriptionPlan {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  priceMonthly Decimal  @db.Decimal(10, 2) @default(0)
  priceAnnual  Decimal  @db.Decimal(10, 2) @default(0)
  features     String[] // list of feature keys
  maxUsers     Int      @default(5)
  maxStores    Int      @default(1)
  maxItems     Int      @default(500)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id              String             @id @default(cuid())
  tenantId        String             @unique
  planId          String
  status          SubscriptionStatus @default(TRIAL)
  interval        BillingInterval    @default(MONTHLY)
  startDate       DateTime
  endDate         DateTime?
  trialEndsAt     DateTime?
  nextBillingDate DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices BillingInvoice[]

  @@index([tenantId])
  @@index([status])
  @@index([nextBillingDate])
}

model BillingInvoice {
  id             String         @id @default(cuid())
  subscriptionId String
  tenantId       String
  invoiceNo      String         @unique
  amount         Decimal        @db.Decimal(10, 2)
  status         InvoiceStatus  @default(UNPAID)
  dueDate        DateTime
  paidAt         DateTime?
  paymentMethod  String?
  paymentRef     String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId, status])
  @@index([dueDate])
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}

// ============================================================
// TIER 6: GRANULAR ROLE PERMISSIONS
// ============================================================

model RolePermission {
  id       String   @id @default(cuid())
  tenantId String
  role     Role?            // Role-level rule (nullable if user-level)
  userId   String?          // User-level override (nullable if role-level)
  resource String           // "pos" | "reports" | "users" | "settings" | ...
  actions  String[]         // ["read","write","delete"]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([tenantId, role, resource])
  @@index([tenantId, userId])
  @@index([tenantId, role])
}
