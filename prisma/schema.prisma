
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
        

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  password     String?
  role         Role     @default(KASIR)
  phone        String?
  image        String?
  isActive     Boolean  @default(true)
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions   Transaction[]
  stockMovements StockMovement[]
  jobTickets     JobTicket[]
  staffBookings  Booking[]       @relation("BookingStaff")

  @@index([email])
}

enum Role {
  OWNER
  MANAGER
  KASIR
}

// ============================================================
// UNIVERSAL ITEM CATALOG
// ============================================================

model ItemCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items Item[]

  @@index([name])
}

model Item {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  type        ItemType  @default(GOODS)
  orderType   OrderType @default(READY)
  categoryId  String?
  images      String[]
  isActive    Boolean  @default(true)
  basePrice   Decimal  @db.Decimal(10, 2)
  baseCost    Decimal? @db.Decimal(10, 2)
  unit        String   @default("pcs")
  taxable     Boolean  @default(true)
  serialTrack Boolean  @default(false)
  taxRateId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       ItemCategory?      @relation(fields: [categoryId], references: [id])
  variants       ItemVariant[]
  bom            BillOfMaterial?
  bomComponents  BomItem[]          @relation("BomComponentItem")
  modifierGroups ItemModifierGroup[]

  @@index([type])
  @@index([categoryId])
  @@index([name])
}

enum ItemType {
  GOODS
  SERVICE
  RAW_MATERIAL
  BUNDLE
}

enum OrderType {
  READY
  PRE_ORDER
}


model ItemVariant {
  id         String   @id @default(cuid())
  itemId     String
  sku        String   @unique
  name       String
  price      Decimal  @db.Decimal(10, 2)
  cost       Decimal? @db.Decimal(10, 2)
  stock      Int      @default(0)
  minStock   Int      @default(10)
  barcode    String?
  isActive   Boolean  @default(true)
  attributes String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  item             Item                @relation(fields: [itemId], references: [id], onDelete: Cascade)
  transactionItems TransactionItem[]
  stockMovements   StockMovement[]
  storeInventory   StoreInventory[]
  batches          ItemBatch[]
  returnItems      ReturnItem[]
  transferItems    StoreTransferItem[]
  purchaseItems    PurchaseItem[]
  opnameItems      StockOpnameItem[]
  bomItems         BomItem[]
  tableOrderItems  TableOrderItem[]
  priceListItems   PriceListItem[]
  consignmentItems ConsignmentItem[]
  serialNumbers    SerialNumber[]

  @@index([isActive])
  @@index([barcode])
  @@index([itemId])
}

// ============================================================
// BILL OF MATERIALS
// ============================================================

model BillOfMaterial {
  id        String   @id @default(cuid())
  itemId    String   @unique
  notes     String?
  yield     Decimal  @db.Decimal(10, 3) @default(1)
  yieldUnit String   @default("pcs")
  prepTime  Int?
  cookTime  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item       Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  components BomItem[]

  @@index([itemId])
}

model BomItem {
  id              String   @id @default(cuid())
  bomId           String
  componentItemId String
  variantId       String?
  quantity        Decimal  @db.Decimal(10, 3)
  unit            String
  notes           String?
  createdAt       DateTime @default(now())

  bom           BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentItem Item           @relation("BomComponentItem", fields: [componentItemId], references: [id])
  variant       ItemVariant?   @relation(fields: [variantId], references: [id])

  @@index([bomId])
  @@index([componentItemId])
  @@index([variantId])
}

// ============================================================
// PRODUCTION ORDERS
// ============================================================

model ProductionOrder {
  id            String           @id @default(cuid())
  orderNo       String           @unique
  status        ProductionStatus @default(PLANNED)
  scheduledDate DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  totalCost     Decimal          @db.Decimal(10, 2) @default(0)
  notes         String?
  userId        String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  items     ProductionOrderItem[]
  materials ProductionMaterial[]

  @@index([status])
  @@index([scheduledDate])
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionOrderItem {
  id               String @id @default(cuid())
  productionId     String
  variantId        String
  itemName         String
  variantName      String
  targetQuantity   Int
  producedQuantity Int    @default(0)
  wasteQuantity    Int    @default(0)
  notes            String?

  production ProductionOrder @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId])
  @@index([variantId])
}

model ProductionMaterial {
  id           String  @id @default(cuid())
  productionId String
  variantId    String
  materialName String
  quantity     Decimal @db.Decimal(10, 3)
  unit         String
  cost         Decimal @db.Decimal(10, 2)

  production ProductionOrder @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId])
  @@index([variantId])
}

model ProductionTarget {
  id             String   @id @default(cuid())
  month          DateTime @unique
  targetQuantity Int      @default(0)
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([month])
}

// ============================================================
// JOB TICKET
// ============================================================

model JobTicket {
  id              String         @id @default(cuid())
  ticketNo        String         @unique
  customerName    String
  customerPhone   String
  customerAddress String?
  title           String
  description     String?
  notes           String?
  referenceImages String[]
  quantity        Int            @default(1)
  unitPrice       Decimal        @db.Decimal(10, 2)
  totalPrice      Decimal        @db.Decimal(10, 2)
  dpAmount        Decimal        @db.Decimal(10, 2) @default(0)
  dpMethod        PaymentMethod?
  dpPaidAt        DateTime?
  remainingAmount Decimal        @db.Decimal(10, 2) @default(0)
  finalPayMethod  PaymentMethod?
  finalPaidAt     DateTime?
  dueDate         DateTime
  deliveryType    DeliveryType   @default(PICKUP)
  status          JobStatus      @default(PENDING)
  cancelReason    String?
  createdBy       String
  customerId      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdByUser User           @relation(fields: [createdBy], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  items         JobTicketItem[]

  @@index([status])
  @@index([dueDate(sort: Asc)])
  @@index([customerPhone])
  @@index([createdAt])
}

model JobTicketItem {
  id        String  @id @default(cuid())
  ticketId  String
  variantId String?
  name      String
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  notes     String?

  ticket JobTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([variantId])
}

enum JobStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

// ============================================================
// TRANSACTIONS
// ============================================================

model Transaction {
  id             String               @id @default(cuid())
  transactionNo  String               @unique
  type           TransactionType      @default(POS_RECEIPT)
  customerId     String?
  userId         String
  shiftId        String?
  subtotal       Decimal              @db.Decimal(10, 2)
  tax            Decimal              @db.Decimal(10, 2)
  discount       Decimal              @db.Decimal(10, 2) @default(0)
  total          Decimal              @db.Decimal(10, 2)
  paymentMethod  PaymentMethod?
  paymentAmount  Decimal              @db.Decimal(10, 2) @default(0)
  changeAmount   Decimal              @db.Decimal(10, 2) @default(0)
  paymentStatus  InvoicePaymentStatus @default(PAID)
  deliveryType   DeliveryType         @default(PICKUP)
  deliveryAddress String?
  dueDate        DateTime?
  notes          String?
  status         TransactionStatus    @default(COMPLETED)
  pointsEarned   Int                  @default(0)
  pointsRedeemed Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  customer Customer?            @relation(fields: [customerId], references: [id])
  user     User                 @relation(fields: [userId], references: [id])
  shift    Shift?               @relation(fields: [shiftId], references: [id])
  items    TransactionItem[]
  payments TransactionPayment[]

  @@index([createdAt(sort: Desc)])
  @@index([type, createdAt])
  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([userId])
  @@index([shiftId])
}

enum TransactionType {
  POS_RECEIPT
  B2B_INVOICE
}

model TransactionPayment {
  id            String        @id @default(cuid())
  transactionId String
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  reference     String?
  createdAt     DateTime      @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

enum InvoicePaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  DEBIT_CARD
  CREDIT_CARD
  EWALLET
  POINTS
}

enum TransactionStatus {
  COMPLETED
  VOID
  REFUNDED
}

model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  variantId     String
  itemName      String
  variantName   String
  quantity      Int
  price         Decimal @db.Decimal(10, 2)
  discount      Decimal @db.Decimal(10, 2) @default(0)
  subtotal      Decimal @db.Decimal(10, 2)
  notes         String?

  transaction Transaction              @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  variant     ItemVariant              @relation(fields: [variantId], references: [id])
  modifiers   TransactionItemModifier[]

  @@index([transactionId])
  @@index([variantId])
}

// ============================================================
// ITEM MODIFIERS / ADD-ONS
// ============================================================

model ItemModifierGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  required  Boolean  @default(false)
  multiple  Boolean  @default(true)
  maxSelect Int?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options ItemModifierOption[]
  items   Item[]

  @@index([isActive])
}

model ItemModifierOption {
  id        String  @id @default(cuid())
  groupId   String
  name      String
  price     Decimal @db.Decimal(10, 2) @default(0)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  group ItemModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model TransactionItemModifier {
  id                 String  @id @default(cuid())
  transactionItemId  String
  modifierGroupName  String
  modifierOptionName String
  price              Decimal @db.Decimal(10, 2)

  transactionItem TransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: Cascade)

  @@index([transactionItemId])
}

// ============================================================
// STOCK MANAGEMENT
// ============================================================

model StockMovement {
  id        String            @id @default(cuid())
  variantId String
  type      StockMovementType
  quantity  Int
  reference String?
  reason    String?
  notes     String?
  userId    String
  createdAt DateTime          @default(now())

  variant ItemVariant @relation(fields: [variantId], references: [id])
  user    User        @relation(fields: [userId], references: [id])

  @@index([variantId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([variantId])
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model ItemBatch {
  id              String   @id @default(cuid())
  variantId       String
  batchNo         String   @unique
  quantity        Int
  remainingQty    Int
  manufactureDate DateTime
  expiryDate      DateTime
  cost            Decimal  @db.Decimal(10, 2)
  supplier        String?
  notes           String?
  discountRate    Decimal  @db.Decimal(5, 2) @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  variant ItemVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([expiryDate])
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id           String       @id @default(cuid())
  name         String
  phone        String?      @unique
  email        String?
  address      String?
  birthDate    DateTime?
  notes        String?
  customerType CustomerType @default(RETAIL)
  creditLimit  Decimal?     @db.Decimal(10, 2)
  priceListId  String?
  segment      String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  transactions  Transaction[]
  loyaltyPoints LoyaltyPoint?
  pointHistory  PointHistory[]
  jobTickets    JobTicket[]
  bookings      Booking[]
  priceList     PriceList?    @relation(fields: [priceListId], references: [id])

  @@index([name])
  @@index([phone])
}

enum CustomerType {
  RETAIL
  WHOLESALE
}

model LoyaltyPoint {
  id          String   @id @default(cuid())
  customerId  String   @unique
  points      Int      @default(0)
  totalEarned Int      @default(0)
  totalSpent  Int      @default(0)
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model PointHistory {
  id          String          @id @default(cuid())
  customerId  String
  points      Int
  type        PointActionType
  reference   String?
  description String?
  createdAt   DateTime        @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
}

enum PointActionType {
  EARN
  REDEEM
  EXPIRE
  ADJUSTMENT
}

// ============================================================
// SUPPLIERS & PURCHASES
// ============================================================

model Supplier {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  address     String?
  contactName String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases Purchase[]

  @@index([name])
}

model Purchase {
  id            String        @id @default(cuid())
  purchaseNo    String        @unique
  supplierId    String
  userId        String
  subtotal      Decimal       @db.Decimal(10, 2)
  tax           Decimal       @db.Decimal(10, 2) @default(0)
  discount      Decimal       @db.Decimal(10, 2) @default(0)
  total         Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@index([supplierId])
  @@index([createdAt])
}

model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String
  variantId   String
  itemName    String
  variantName String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  purchase Purchase    @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant  ItemVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([variantId])
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

// ============================================================
// DISCOUNTS
// ============================================================

model Discount {
  id          String       @id @default(cuid())
  name        String
  code        String?      @unique
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)
  minPurchase Decimal?     @db.Decimal(10, 2)
  maxDiscount Decimal?     @db.Decimal(10, 2)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean      @default(true)
  usageLimit  Int?
  usageCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([isActive])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ============================================================
// EXPENSES
// ============================================================

model Expense {
  id            String          @id @default(cuid())
  category      ExpenseCategory
  amount        Decimal         @db.Decimal(10, 2)
  date          DateTime        @default(now())
  description   String
  paymentMethod PaymentMethod
  reference     String?
  notes         String?
  attachments   String[]
  userId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([date(sort: Desc)])
  @@index([category, date])
}

enum ExpenseCategory {
  SALARY
  UTILITIES
  RAW_MATERIALS
  SUPPLIES
  RENT
  MAINTENANCE
  MARKETING
  TRANSPORTATION
  TAX_FEE
  OTHER
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  data      String?
  isRead    Boolean          @default(false)
  userId    String?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  NEW_ORDER
  SYSTEM
}

// ============================================================
// SETTINGS — Singleton
// ============================================================

model Settings {
  id                     String    @id @default(cuid())
  businessName           String    @default("My Business")
  businessAddress        String?
  businessPhone          String?
  businessEmail          String?
  logo                   String?
  taxRate                Decimal   @db.Decimal(5, 2) @default(11)
  taxIncluded            Boolean   @default(false)
  currency               String    @default("IDR")
  receiptHeader          String?
  receiptFooter          String?
  lowStockThreshold      Int       @default(10)
  whatsappEnabled        Boolean   @default(false)
  whatsappTenantId       String?
  whatsappConnected      Boolean   @default(false)
  whatsappLastConnected  DateTime?
  notifyOnTransaction    Boolean   @default(false)
  notifyOnLowStock       Boolean   @default(true)
  notifyOnBackup         Boolean   @default(true)
  notifyDailyReport      Boolean   @default(false)
  ownerPhone             String?
  qrisString             String?   @db.Text
  loyaltyEnabled         Boolean   @default(false)
  loyaltyPointsPerRupiah Int       @default(1000)
  loyaltyPointValue      Int       @default(1)
  tableEnabled           Boolean   @default(false)
  kdsEnabled             Boolean   @default(false)
  tierPricingEnabled     Boolean   @default(false)
  serialTrackEnabled     Boolean   @default(false)
  consignmentEnabled     Boolean   @default(false)
  accountingEnabled      Boolean   @default(false)
  bankReconEnabled       Boolean   @default(false)
  payrollEnabled         Boolean   @default(false)
  marketingEnabled       Boolean   @default(false)
  feedbackEnabled        Boolean   @default(false)
  onlineOrderEnabled     Boolean   @default(false)
  webhooksEnabled        Boolean   @default(false)
  updatedAt              DateTime  @updatedAt
}

// ============================================================
// SHIFTS
// ============================================================

model Shift {
  id               String      @id @default(cuid())
  shiftNo          String      @unique
  userId           String
  storeId          String?
  openedAt         DateTime    @default(now())
  closedAt         DateTime?
  status           ShiftStatus @default(OPEN)
  openingBalance   Decimal     @db.Decimal(10, 2)
  closingBalance   Decimal?    @db.Decimal(10, 2)
  actualCash       Decimal?    @db.Decimal(10, 2)
  variance         Decimal?    @db.Decimal(10, 2)
  totalSales       Decimal     @db.Decimal(10, 2) @default(0)
  totalCash        Decimal     @db.Decimal(10, 2) @default(0)
  totalTransfer    Decimal     @db.Decimal(10, 2) @default(0)
  totalQris        Decimal     @db.Decimal(10, 2) @default(0)
  totalCard        Decimal     @db.Decimal(10, 2) @default(0)
  transactionCount Int         @default(0)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  transactions Transaction[]
  store        Store?        @relation(fields: [storeId], references: [id])

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([openedAt])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// ============================================================
// RETURNS
// ============================================================

model Return {
  id            String        @id @default(cuid())
  returnNo      String        @unique
  transactionId String
  transactionNo String
  customerId    String?
  userId        String
  reason        String
  status        ReturnStatus  @default(PENDING)
  subtotal      Decimal       @db.Decimal(10, 2)
  refundAmount  Decimal       @db.Decimal(10, 2)
  refundMethod  PaymentMethod
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items ReturnItem[]

  @@index([transactionId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model ReturnItem {
  id            String  @id @default(cuid())
  returnId      String
  variantId     String
  itemName      String
  variantName   String
  quantity      Int
  price         Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)
  returnToStock Boolean @default(true)
  condition     String?

  return  Return      @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant ItemVariant @relation(fields: [variantId], references: [id])

  @@index([returnId])
  @@index([variantId])
}

// ============================================================
// STOCK OPNAME
// ============================================================

model StockOpname {
  id            String       @id @default(cuid())
  opnameNo      String       @unique
  scheduledDate DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  status        OpnameStatus @default(SCHEDULED)
  storeId       String?
  countedBy     String?
  verifiedBy    String?
  totalItems    Int          @default(0)
  totalVariance Int          @default(0)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items StockOpnameItem[]
  store Store?            @relation(fields: [storeId], references: [id])

  @@index([status])
  @@index([storeId])
  @@index([scheduledDate])
}

enum OpnameStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model StockOpnameItem {
  id           String  @id @default(cuid())
  opnameId     String
  variantId    String
  itemName     String
  variantName  String
  systemStock  Int
  countedStock Int     @default(0)
  variance     Int     @default(0)
  reason       String?
  condition    String?
  adjusted     Boolean @default(false)
  notes        String?

  opname  StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  variant ItemVariant @relation(fields: [variantId], references: [id])

  @@index([opnameId])
  @@index([variantId])
}

// ============================================================
// MULTI-STORE
// ============================================================

model Store {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  address     String?
  phone       String?
  email       String?
  manager     String?
  isActive    Boolean  @default(true)
  isMainStore Boolean  @default(false)
  settings    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shifts         Shift[]
  stockOpnames   StockOpname[]
  storeInventory StoreInventory[]
  transfersFrom  StoreTransfer[]  @relation("TransferFrom")
  transfersTo    StoreTransfer[]  @relation("TransferTo")

  @@index([isActive])
}

model StoreInventory {
  id        String   @id @default(cuid())
  storeId   String
  variantId String
  stock     Int      @default(0)
  minStock  Int      @default(10)
  maxStock  Int?
  updatedAt DateTime @updatedAt

  store   Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ItemVariant @relation(fields: [variantId], references: [id])

  @@unique([storeId, variantId])
  @@index([storeId])
  @@index([variantId])
}

model StoreTransfer {
  id          String         @id @default(cuid())
  transferNo  String         @unique
  fromStoreId String
  toStoreId   String
  status      TransferStatus @default(PENDING)
  requestedBy String
  approvedBy  String?
  receivedBy  String?
  requestedAt DateTime       @default(now())
  approvedAt  DateTime?
  receivedAt  DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  fromStore Store               @relation("TransferFrom", fields: [fromStoreId], references: [id])
  toStore   Store               @relation("TransferTo", fields: [toStoreId], references: [id])
  items     StoreTransferItem[]

  @@index([fromStoreId])
  @@index([toStoreId])
  @@index([status])
}

enum TransferStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  RECEIVED
  REJECTED
}

model StoreTransferItem {
  id          String  @id @default(cuid())
  transferId  String
  variantId   String
  itemName    String
  variantName String
  quantity    Int
  receivedQty Int     @default(0)
  notes       String?

  transfer StoreTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ItemVariant   @relation(fields: [variantId], references: [id])

  @@index([transferId])
  @@index([variantId])
}

// ============================================================
// TIER 2: TABLE MANAGEMENT
// ============================================================

model Table {
  id        String      @id @default(cuid())
  storeId   String?
  number    String      @unique
  name      String?
  capacity  Int         @default(4)
  floor     String?
  status    TableStatus @default(AVAILABLE)
  qrToken   String      @unique @default(cuid())
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  activeOrder TableOrder?

  @@index([status])
  @@index([isActive])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

model TableOrder {
  id            String           @id @default(cuid())
  tableId       String           @unique
  orderNo       String           @unique
  customerId    String?
  guestName     String?
  guestCount    Int              @default(1)
  status        TableOrderStatus @default(OPEN)
  notes         String?
  openedBy      String
  openedAt      DateTime         @default(now())
  closedAt      DateTime?
  transactionId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  table          Table            @relation(fields: [tableId], references: [id])
  items          TableOrderItem[]
  kitchenTickets KitchenTicket[]

  @@index([status])
  @@index([tableId])
}

enum TableOrderStatus {
  OPEN
  BILL_REQUESTED
  PAID
  CANCELLED
}

model TableOrderItem {
  id           String            @id @default(cuid())
  tableOrderId String
  variantId    String
  itemName     String
  variantName  String
  quantity     Int
  price        Decimal           @db.Decimal(10, 2)
  notes        String?
  status       KitchenItemStatus @default(PENDING)
  sentAt       DateTime?
  createdAt    DateTime          @default(now())

  tableOrder TableOrder  @relation(fields: [tableOrderId], references: [id], onDelete: Cascade)
  variant    ItemVariant @relation(fields: [variantId], references: [id])

  @@index([tableOrderId])
  @@index([variantId])
}

// ============================================================
// TIER 2: KITCHEN DISPLAY SYSTEM (KDS)
// ============================================================

model KitchenTicket {
  id           String        @id @default(cuid())
  ticketNo     String        @unique
  tableOrderId String?
  tableNumber  String?
  source       KitchenSource @default(POS)
  status       KitchenStatus @default(PENDING)
  priority     Int           @default(0)
  notes        String?
  startedAt    DateTime?
  readyAt      DateTime?
  servedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tableOrder TableOrder?         @relation(fields: [tableOrderId], references: [id])
  items      KitchenTicketItem[]

  @@index([status])
  @@index([tableOrderId])
  @@index([createdAt])
}

model KitchenTicketItem {
  id          String            @id @default(cuid())
  ticketId    String
  variantId   String?
  itemName    String
  quantity    Int
  notes       String?
  status      KitchenItemStatus @default(PENDING)
  completedAt DateTime?

  ticket KitchenTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

enum KitchenStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum KitchenSource {
  TABLE
  POS
  SELF_ORDER
}

enum KitchenItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

// ============================================================
// TIER 2: BOOKINGS / APPOINTMENTS
// ============================================================

model Booking {
  id            String        @id @default(cuid())
  bookingNo     String        @unique
  customerId    String?
  customerName  String
  customerPhone String?
  serviceId     String?
  serviceName   String
  staffId       String?
  storeId       String?
  date          DateTime
  startTime     DateTime
  endTime       DateTime?
  duration      Int?
  status        BookingStatus @default(PENDING)
  notes         String?
  reminderSent  Boolean       @default(false)
  depositPaid   Decimal?      @db.Decimal(10, 2)
  totalAmount   Decimal?      @db.Decimal(10, 2)
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  staff    User?     @relation("BookingStaff", fields: [staffId], references: [id])

  @@index([date])
  @@index([status])
  @@index([staffId])
  @@index([customerId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================================
// TIER 3: TIER PRICING / PRICE LIST
// ============================================================

model PriceList {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  minOrderQty Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items     PriceListItem[]
  customers Customer[]

  @@index([isActive])
}

model PriceListItem {
  id          String  @id @default(cuid())
  priceListId String
  variantId   String
  price       Decimal @db.Decimal(10, 2)
  minQty      Int     @default(1)

  priceList PriceList   @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  variant   ItemVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([priceListId, variantId])
  @@index([priceListId])
  @@index([variantId])
}

// ============================================================
// TIER 3: CONSIGNMENT / TITIP JUAL
// ============================================================

model Consignment {
  id             String            @id @default(cuid())
  consignNo      String            @unique
  consignerName  String
  consignerPhone String?
  supplierId     String?
  startDate      DateTime
  endDate        DateTime?
  status         ConsignmentStatus @default(ACTIVE)
  notes          String?
  commission     Decimal           @db.Decimal(5, 2) @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  items ConsignmentItem[]

  @@index([status])
}

model ConsignmentItem {
  id            String   @id @default(cuid())
  consignmentId String
  variantId     String
  itemName      String
  variantName   String
  consignedQty  Int
  soldQty       Int      @default(0)
  returnedQty   Int      @default(0)
  consignPrice  Decimal  @db.Decimal(10, 2)
  salePrice     Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  consignment Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  variant     ItemVariant @relation(fields: [variantId], references: [id])

  @@index([consignmentId])
  @@index([variantId])
}

enum ConsignmentStatus {
  ACTIVE
  SETTLED
  RETURNED
  CANCELLED
}

// ============================================================
// TIER 3: SERIAL NUMBER TRACKING
// ============================================================

model SerialNumber {
  id            String             @id @default(cuid())
  variantId     String
  serialNo      String             @unique
  status        SerialNumberStatus @default(IN_STOCK)
  purchaseRef   String?
  transactionId String?
  customerId    String?
  soldAt        DateTime?
  returnedAt    DateTime?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  variant ItemVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([variantId])
  @@index([transactionId])
}

enum SerialNumberStatus {
  IN_STOCK
  SOLD
  RETURNED
  DEFECTIVE
  RESERVED
}

// ============================================================
// TIER 4: CHART OF ACCOUNTS
// ============================================================

model Account {
  id             String      @id @default(cuid())
  code           String      @unique
  name           String
  type           AccountType
  normalBalance  BalanceSide @default(DEBIT)
  parentId       String?
  description    String?
  isActive       Boolean     @default(true)
  isSystem       Boolean     @default(false)
  currentBalance Decimal     @db.Decimal(15, 2) @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  parent   Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[]     @relation("AccountHierarchy")
  lines    JournalLine[]

  @@index([type])
  @@index([isActive])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum BalanceSide {
  DEBIT
  CREDIT
}

model JournalEntry {
  id          String   @id @default(cuid())
  entryNo     String   @unique
  date        DateTime
  description String
  reference   String?
  sourceType  String?
  sourceId    String?
  isPosted    Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalLine[]

  @@index([date])
  @@index([isPosted])
  @@index([sourceId])
}

model JournalLine {
  id          String  @id @default(cuid())
  entryId     String
  accountId   String
  description String?
  debit       Decimal @db.Decimal(15, 2) @default(0)
  credit      Decimal @db.Decimal(15, 2) @default(0)
  sortOrder   Int     @default(0)

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
}

// ============================================================
// TIER 4: BANK RECONCILIATION
// ============================================================

model BankAccount {
  id             String   @id @default(cuid())
  bankName       String
  accountNumber  String   @unique
  accountName    String
  currentBalance Decimal  @db.Decimal(15, 2) @default(0)
  currency       String   @default("IDR")
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  statements BankStatement[]

  @@index([isActive])
}

model BankStatement {
  id            String     @id @default(cuid())
  bankAccountId String
  date          DateTime
  description   String
  amount        Decimal    @db.Decimal(15, 2)
  type          BankTxType
  reference     String?
  balance       Decimal?   @db.Decimal(15, 2)
  isReconciled  Boolean    @default(false)
  transactionId String?
  notes         String?
  createdAt     DateTime   @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([date])
  @@index([isReconciled])
}

enum BankTxType {
  CREDIT
  DEBIT
}

// ============================================================
// TIER 4: TAX RATES
// ============================================================

model TaxRate {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  rate        Decimal  @db.Decimal(5, 2)
  isDefault   Boolean  @default(false)
  isInclusive Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// ============================================================
// TIER 4: PAYROLL
// ============================================================

model Employee {
  id          String   @id @default(cuid())
  userId      String?
  employeeNo  String   @unique
  name        String
  position    String?
  department  String?
  joinDate    DateTime
  baseSalary  Decimal  @db.Decimal(15, 2)
  bankName    String?
  bankAccount String?
  bankHolder  String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances    Attendance[]
  payrollEntries PayrollEntry[]

  @@index([isActive])
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  notes      String?
  createdAt  DateTime         @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([date])
  @@index([employeeId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  HOLIDAY
  LEAVE
}

model PayrollPeriod {
  id          String        @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      PayrollStatus @default(DRAFT)
  notes       String?
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  entries PayrollEntry[]

  @@index([status])
  @@index([startDate])
}

model PayrollEntry {
  id          String        @id @default(cuid())
  periodId    String
  employeeId  String
  workingDays Int           @default(0)
  presentDays Int           @default(0)
  baseSalary  Decimal       @db.Decimal(15, 2)
  allowances  Decimal       @db.Decimal(15, 2) @default(0)
  deductions  Decimal       @db.Decimal(15, 2) @default(0)
  netSalary   Decimal       @db.Decimal(15, 2)
  bankName    String?
  bankAccount String?
  status      PayrollStatus @default(DRAFT)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  period   PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id])

  @@unique([periodId, employeeId])
  @@index([periodId])
  @@index([employeeId])
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
  CANCELLED
}

// ============================================================
// TIER 5: MARKETING CAMPAIGNS
// ============================================================

model MarketingCampaign {
  id              String         @id @default(cuid())
  name            String
  type            CampaignType
  targetSegment   String?
  message         String         @db.Text
  imageUrl        String?
  status          CampaignStatus @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int            @default(0)
  sentCount       Int            @default(0)
  failedCount     Int            @default(0)
  createdBy       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  recipients CampaignRecipient[]

  @@index([status])
  @@index([scheduledAt])
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  customerId String?
  name       String?
  contact    String
  status     RecipientStatus @default(PENDING)
  sentAt     DateTime?
  errorMsg   String?

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([customerId])
}

enum CampaignType {
  WHATSAPP
  EMAIL
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// ============================================================
// TIER 5: CUSTOMER FEEDBACK / NPS
// ============================================================

model CustomerFeedback {
  id            String   @id @default(cuid())
  customerId    String?
  transactionId String?
  rating        Int
  comment       String?  @db.Text
  channel       String   @default("LINK")
  staffName     String?
  storeId       String?
  isPublic      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([rating])
  @@index([customerId])
  @@index([transactionId])
}

// ============================================================
// TIER 6: WEBHOOKS
// ============================================================

model WebhookEndpoint {
  id          String   @id @default(cuid())
  url         String
  description String?
  events      String[]
  secret      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs WebhookLog[]

  @@index([isActive])
}

model WebhookLog {
  id           String    @id @default(cuid())
  endpointId   String
  event        String
  payload      String    @db.Text
  status       String    @default("PENDING")
  responseCode Int?
  responseBody String?   @db.Text
  attemptCount Int       @default(0)
  nextRetryAt  DateTime?
  createdAt    DateTime  @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([endpointId])
  @@index([status])
}

// ============================================================
// TIER 6: MARKETPLACE INTEGRATION
// ============================================================

model MarketplaceIntegration {
  id          String    @id @default(cuid())
  platform    String    @unique
  shopId      String?
  shopName    String?
  apiKey      String?   @db.Text
  apiSecret   String?   @db.Text
  accessToken String?   @db.Text
  isActive    Boolean   @default(false)
  lastSyncAt  DateTime?
  syncStatus  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders MarketplaceOrder[]

  @@index([isActive])
}

model MarketplaceOrder {
  id              String   @id @default(cuid())
  integrationId   String
  externalOrderId String
  platform        String
  status          String
  customerName    String?
  customerPhone   String?
  items           String   @db.Text
  subtotal        Decimal  @db.Decimal(10, 2) @default(0)
  shippingFee     Decimal  @db.Decimal(10, 2) @default(0)
  total           Decimal  @db.Decimal(10, 2) @default(0)
  transactionId   String?
  syncedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalOrderId])
  @@index([platform])
  @@index([status])
}

// ============================================================
// TIER 6: GRANULAR ROLE PERMISSIONS
// ============================================================

model RolePermission {
  id        String   @id @default(cuid())
  role      Role?
  userId    String?
  resource  String
  actions   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, resource])
  @@index([userId])
  @@index([role])
}
